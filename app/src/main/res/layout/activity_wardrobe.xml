<?xml version="1.0" encoding="utf-8" ?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/ic_background">

    <include layout="@layout/toolbar"/>


    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/wardrobeText"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toTopOf="@id/categories"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="WARDROBE"
        android:textColor="@color/black"
        android:textAlignment="center"
        android:textSize="52sp"
        android:textStyle="bold">

    </TextView>

    <HorizontalScrollView
        android:id="@+id/categories"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="1dp"
        app:layout_constraintTop_toBottomOf="@+id/wardrobeText">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent">

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="center_horizontal"
                >

                <ImageButton
                    android:id="@+id/icon"
                    android:layout_width="300dp"
                    android:layout_height="450dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/tops_icon"
                    android:background="@android:color/transparent"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOPS"
                    android:textAlignment="center"
                    android:textColor="#FFFFFF"
                    android:textSize="32"
                    android:layout_centerInParent="true"
                    android:layout_alignParentBottom="true"
                    android:background="@color/colorPrimary"/>
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="center_horizontal"
                >

                <ImageButton
                    android:layout_width="300dp"
                    android:layout_height="450dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/bottoms_icon"
                    android:background="@android:color/transparent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BOTTOMS"
                    android:textAlignment="center"
                    android:textColor="#FFFFFF"
                    android:textSize="28"
                    android:layout_centerInParent="true"
                    android:layout_alignParentBottom="true"
                    android:background="@color/colorPrimary"/>
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="center_horizontal"
                >

                <ImageButton
                    android:layout_width="300dp"
                    android:layout_height="450dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/dresses_icon"
                    android:background="@android:color/transparent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FULL BODY"
                    android:textAlignment="center"
                    android:textColor="#FFFFFF"
                    android:textSize="28"
                    android:layout_centerInParent="true"
                    android:layout_alignParentBottom="true"
                    android:background="@color/colorPrimary"/>
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                >

                <ImageButton
                    android:layout_width="300dp"
                    android:layout_height="450dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/shoes_icon"
                    android:background="@android:color/transparent"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="SHOES"
                    android:textAlignment="center"
                    android:textColor="#FFFFFF"
                    android:textSize="28"
                    android:layout_centerInParent="true"
                    android:layout_alignParentBottom="true"
                    android:background="@color/colorPrimary"/>
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                >

                <ImageButton
                    android:layout_width="300dp"
                    android:layout_height="450dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/accessories_icon"
                    android:background="@android:color/transparent"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACCESSORIES"
                    android:textAlignment="center"
                    android:textColor="#FFFFFF"
                    android:textSize="28"
                    android:layout_centerInParent="true"
                    android:background="@color/colorPrimary"/>
            </RelativeLayout>

        </LinearLayout>

    </HorizontalScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>